#!/usr/bin/env python3
"""
NeuralOS CLI Tool - Main entry point
"""

import sys
import json

sys.path.insert(0, '/usr/lib/nos')

from nos import NeuralNode
from nos.system import create_node


def main():
    if len(sys.argv) < 2:
        print("NeuralOS CLI v0.1.0")
        print("\nUsage: nos <command> [args]")
        print("\nCommands:")
        print("  diagnose     - System diagnosis")
        print("  status       - System dashboard")
        print("  find <q>     - Search files")
        print("  install <p>  - Install package")
        print("  memory       - Memory report")
        print("  cache        - Cache stats")
        print("  predict      - Resource forecast")
        print("  --json       - Output as JSON")
        sys.exit(1)
    
    # Create node
    node = create_node('cli')
    
    # Check for JSON output
    json_output = '--json' in sys.argv
    args = [a for a in sys.argv[1:] if a != '--json']
    
    # Build command
    cmd = ' '.join(args)
    
    # Run command
    result = node.run_command(cmd)
    
    if json_output:
        print(json.dumps(result, indent=2, default=str))
    else:
        print_result(result)


def print_result(result: dict):
    """Pretty print result."""
    rtype = result.get('type', 'unknown')
    
    if rtype == 'diagnostic':
        print(result.get('message', ''))
    
    elif rtype == 'file_search':
        print(f"Search results for '{result.get('query')}':")
        for score, path, tags in result.get('results', []):
            print(f"  [{score:.2f}] {path}")
    
    elif rtype == 'memory_report':
        report = result.get('report', {})
        print("Memory Report:")
        print(f"  Compression: {report.get('compression_ratio', 0):.2f}x")
        print(f"  Savings: {report.get('savings_mb', 0):.1f} MB")
    
    elif rtype == 'cache_report':
        report = result.get('report', {})
        print("Cache Report:")
        print(f"  Hit rate: {report.get('hit_rate_pct', 0):.1f}%")
    
    elif rtype == 'dashboard':
        data = result.get('data', {})
        print(f"NeuralOS Dashboard - {data.get('node_id')}")
        print(f"  Mode: {data.get('current_mode')}")
        print(f"  Uptime: {data.get('uptime_seconds', 0):.0f}s")
    
    else:
        print(result.get('hint', str(result)))


if __name__ == '__main__':
    main()
