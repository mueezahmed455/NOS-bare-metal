#!/usr/bin/env python3
"""
NeuralOS System Information Tool
Neofetch-style system display
"""

import os
import sys
import time

sys.path.insert(0, '/usr/lib/nos')


def get_uptime():
    """Get system uptime."""
    try:
        with open('/proc/uptime') as f:
            return float(f.read().split()[0])
    except Exception:
        return 0


def get_load_avg():
    """Get load average."""
    try:
        with open('/proc/loadavg') as f:
            return f.read().split()[:3]
    except Exception:
        return ['0.00', '0.00', '0.00']


def get_kernel_version():
    """Get kernel version."""
    try:
        with open('/proc/version') as f:
            parts = f.read().split()
            return parts[2] if len(parts) > 2 else 'unknown'
    except Exception:
        return 'unknown'


def get_memory_info():
    """Get memory information."""
    try:
        import psutil
        mem = psutil.virtual_memory()
        return {
            'total': mem.total / 1e9,
            'used': mem.used / 1e9,
            'percent': mem.percent
        }
    except Exception:
        return {'total': 0, 'used': 0, 'percent': 0}


def get_cpu_info():
    """Get CPU information."""
    try:
        import psutil
        return {
            'count': psutil.cpu_count(),
            'percent': psutil.cpu_percent()
        }
    except Exception:
        return {'count': 1, 'percent': 0}


def get_nos_state():
    """Get NeuralOS state."""
    state_path = '/var/lib/nos/state.json'
    try:
        import json
        with open(state_path) as f:
            return json.load(f)
    except Exception:
        return {'boot_count': 1, 'install_date': time.time()}


def print_color(color, text):
    """Print colored text."""
    colors = {
        'cyan': '\033[1;36m',
        'green': '\033[1;32m',
        'yellow': '\033[1;33m',
        'blue': '\033[1;34m',
        'magenta': '\033[1;35m',
        'red': '\033[1;31m',
        'reset': '\033[0m',
        'bold': '\033[1m'
    }
    print(f"{colors.get(color, '')}{text}{colors['reset']}")


def print_logo():
    """Print NeuralOS ASCII logo."""
    logo = """
\033[1;36m       _   _                 _     
      | \ | | __ _ _ __   __| |___ 
      |  \| |/ _` | '_ \ / _` / __|
      | |\  | (_| | | | | (_| \__ \\
      |_| \_|\__,_|_| |_|\__,_|___/
\033[0m"""
    print(logo)


def main():
    print_logo()
    print()
    
    # Get system info
    uptime = get_uptime()
    load = get_load_avg()
    kernel = get_kernel_version()
    mem = get_memory_info()
    cpu = get_cpu_info()
    state = get_nos_state()
    
    # Format uptime
    hours, remainder = divmod(int(uptime), 3600)
    minutes, seconds = divmod(remainder, 60)
    uptime_str = f"{hours}h {minutes}m {seconds}s"
    
    # Right column
    print_color('bold', '  OS:')
    print(f"    \033[1;32mNeuralOS\033[0m v0.1.0 (Synapse)")
    
    print_color('bold', '  Kernel:')
    print(f"    {kernel}")
    
    print_color('bold', '  Uptime:')
    print(f"    {uptime_str}")
    
    print_color('bold', '  Load:')
    print(f"    {', '.join(load)}")
    
    print_color('bold', '  CPU:')
    print(f"    {cpu['count']} cores, {cpu['percent']}%")
    
    print_color('bold', '  Memory:')
    print(f"    {mem['used']:.1f}/{mem['total']:.1f} GB ({mem['percent']}%)")
    
    print_color('bold', '  Boot count:')
    print(f"    {state.get('boot_count', 1)}")
    
    print()
    
    # Color palette
    print("  \033[40m   \033[41m   \033[42m   \033[43m   \033[44m   \033[45m   \033[46m   \033[47m")
    print("  blk  red  grn  yel  blu  mag  cyn  wht")
    
    print()
    print_color('cyan', '  AI is the OS')


if __name__ == '__main__':
    main()
